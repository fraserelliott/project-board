<local:AppWindow x:Class="ProjectBoard.Windows.ProjectWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:vmtasks="clr-namespace:ProjectBoard.ViewModels.Tasks"
                 xmlns:vmnotes="clr-namespace:ProjectBoard.ViewModels.Notes"
                 xmlns:views="clr-namespace:ProjectBoard.Windows" xmlns:local="clr-namespace:ProjectBoard.Windows"
                 xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                 xmlns:controls="clr-namespace:ProjectBoard.Controls" mc:Ignorable="d" Title="{Binding Title}"
                 Height="600" Width="1000" Foreground="{StaticResource TextPrimary}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vmtasks:TasksViewModel}">
            <views:TasksView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmnotes:NotesViewModel}">
            <views:NotesView />
        </DataTemplate>
    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:ProjectWindow.CloseProjectCommand}" Executed="CloseProject_Click" />
        <CommandBinding Command="{x:Static local:ProjectWindow.CloseWindowCommand}" Executed="Exit_Click" />
    </Window.CommandBindings>

    <Window.InputBindings>
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding Tasks.NewTaskCommand}" />
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding Notes.NewNoteCommand}" />
        <KeyBinding Key="W" Modifiers="Control" Command="{x:Static local:ProjectWindow.CloseProjectCommand}" />
        <KeyBinding Key="Q" Modifiers="Control" Command="{x:Static local:ProjectWindow.CloseWindowCommand}" />
    </Window.InputBindings>

    <Border Background="{StaticResource AppBackground}" BorderBrush="{StaticResource BrushBorderSubtle}"
            BorderThickness="1">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="0,0,0,20" Height="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="../Assets/Images/Logo.png" Margin="10,10,30,10" />

                <Menu Grid.Column="1" Background="Transparent" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                      VerticalAlignment="Center">
                    <MenuItem Header="_File" Background="Transparent" FontSize="14">
                        <MenuItem Header="New Task" Click="NewTask_Click" InputGestureText="Ctrl+T" />
                        <MenuItem Header="New Note" Click="NewNote_Click" InputGestureText="Ctrl+N" />
                        <MenuItem Header="Close Project" Click="CloseProject_Click" InputGestureText="Ctrl+W" />
                        <MenuItem Header="Exit" Click="Exit_Click" InputGestureText="Ctrl+Q" />
                    </MenuItem>
                </Menu>

                <controls:TitleBarControl Grid.Column="2" RenderTitle="False" />
            </Grid>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- tabs -->
                    <RowDefinition Height="*" />
                    <!-- content -->
                </Grid.RowDefinitions>

                <!-- Tabs (top-left) -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="18,10,12,0" HorizontalAlignment="Left">
                    <!-- Tasks tab -->
                    <Button Content="Tasks" Command="{Binding ShowTasksCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTasksActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BtnPrimary}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BtnPrimary}" />
                                        <Setter Property="BorderThickness" Value="1,1,1,0" />
                                        <Setter Property="Margin" Value="0,0,6,-1" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTasksActive}" Value="False">
                                        <Setter Property="Margin" Value="0,0,6,0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Notes tab -->
                    <Button Content="Notes" Command="{Binding ShowNotesCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNotesActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BtnPrimary}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BtnPrimary}" />
                                        <Setter Property="BorderThickness" Value="1,1,1,0" />
                                        <Setter Property="Margin" Value="0,0,6,-1" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsNotesActive}" Value="False">
                                        <Setter Property="Margin" Value="0,0,6,0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Content surface -->
                <Border Grid.Row="1" Margin="12,0,12,12" Padding="8" CornerRadius="6" BorderThickness="1"
                        BorderBrush="{StaticResource BtnPrimary}" Background="{StaticResource SurfaceBackground}">
                    <ContentControl Content="{Binding CurrentViewModel}" />
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</local:AppWindow>